{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "用于扫描 Codex Mobile 连接二维码。",
        "NSMicrophoneUsageDescription": "用于语音输入，将讲话内容转换为文字。",
        "NSSpeechRecognitionUsageDescription": "用于语音输入，将讲话内容转换为文字。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "用于扫描 Codex Mobile 连接二维码。"
        }
      ],
      "expo-secure-store",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "用于语音输入，将讲话内容转换为文字。",
          "speechRecognitionPermission": "用于语音输入，将讲话内容转换为文字。"
        }
      ]
    ]
  }
}
